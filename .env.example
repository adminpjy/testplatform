# Backend runtime
PYTHONPATH=backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173
RUNS_ROOT=artifacts/runs
WORKSPACES_ROOT=data/ai-test/workspaces
EXECUTOR_PATH=executor/run_case.py
EXECUTOR_MODE=cube
MAX_CONCURRENT_RUNS=2
RUN_TIMEOUT_SECONDS=600
ALLOWED_BASE_URL_PREFIXES=http://localhost:5174,http://127.0.0.1:5174,http://test.example.com,https://work.bypc.com.cn

# LLM parser
LLM_PROVIDER=openai_compatible
TEST_LLM_BASE_URL=https://ds.ai.sinopec.com/ds_v4_pro/v1/chat/completions
TEST_LLM_API_KEY=
TEST_LLM_MODEL=DeepSeek-V4
TEST_LLM_TIMEOUT_SECONDS=120
TEST_LLM_MAX_TOKENS=8192
TEST_LLM_TEMPERATURE=0
TEST_LLM_TOP_P=0.95
TEST_LLM_STREAM=true
TEST_LLM_VERIFY_SSL=false
TEST_LLM_CA_BUNDLE=

# Cube / local execution defaults
CUBE_API_URL=http://127.0.0.1:3000
CUBE_API_KEY=
CUBE_BROWSER_TEMPLATE_ID=
CUBE_TEMPLATE_ID=
CUBE_CDP_PORT=9000
CUBE_SANDBOX_TIMEOUT_SECONDS=900
CUBE_SANDBOX_TTL_SECONDS=900
KEEP_SANDBOX_ON_FAILURE=true
LOCAL_BROWSER=true

# Vision fallback
VISION_FALLBACK_ENABLED=false
VISION_MODEL_PROVIDER=
VISION_MODEL_ENDPOINT=
VISION_MODEL_API_KEY=
VISION_MODEL_TIMEOUT=30

# Playwright network/runtime
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=true
PLAYWRIGHT_AUTO_CONTINUE_SECURITY_INTERSTITIAL=true
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_BYPASS=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
PLAYWRIGHT_USER_AGENT=
PLAYWRIGHT_CLIENT_CERT_ORIGIN=
PLAYWRIGHT_CLIENT_CERT_PATH=
PLAYWRIGHT_CLIENT_KEY_PATH=
PLAYWRIGHT_CLIENT_CERT_PFX_PATH=
PLAYWRIGHT_CLIENT_CERT_PASSPHRASE=

# Playwright Trace Viewer
TRACE_VIEWER_ENABLED=true
TRACE_VIEWER_HOST=0.0.0.0
TRACE_VIEWER_PUBLIC_HOST=localhost
TRACE_VIEWER_PORT_START=39000
TRACE_VIEWER_PORT_END=39100
TRACE_VIEWER_IDLE_TIMEOUT_SECONDS=600

# Real MIS target
REAL_MIS_BASE_URL=
REAL_MIS_LOGIN_URL=
REAL_MIS_USERNAME=
REAL_MIS_PASSWORD=

# Goal executor
GOAL_MAX_ITERATIONS=12
GOAL_TOTAL_TIMEOUT_MS=90000
GOAL_SINGLE_ACTION_TIMEOUT_MS=15000
LOGIN_RESULT_WAIT_MS=5000
LOGIN_RESULT_RECHECK_TIMES=2
LOGIN_AUTO_RETRY_ON_FAILURE=false
LOGIN_MAX_AUTO_RETRY=0
LOGIN_STOP_ON_CAPTCHA=true
LOGIN_STOP_ON_REMAINING_RETRIES=true

# Persistence
DATABASE_URL=postgresql+psycopg2://admin:123456@host.docker.internal:5432/postgres
ARTIFACTS_DIR=artifacts
REPORTS_DIR=reports
DATA_DIR=data
LOCAL_SECRET_KEY=change-this-local-secret
